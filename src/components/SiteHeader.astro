---
// Statische header voor subpagina's (koraal). De homepage heeft z'n eigen meekleurende variant.
const base = import.meta.env.BASE_URL;
---
<header class="header" id="header" style="--hdr-bg:var(--coral)">
  <nav class="nav" aria-label="Hoofdnavigatie">
    <a class="brand" href={base}><img class="brand-logo" src={base + 'logos/avatar-white.png'} alt="Studio Wotto" /></a>
    <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-label="Menu"><span></span><span></span><span></span></button>
    <ul class="nav-links">
      <li><a href={base + 'projecten'}>Projecten</a></li>
      <li><a href={base + 'blog'}>Blog</a></li>
      <li><a href={base + '#over'}>Over ons</a></li>
      <li><a href={base + '#contact'}>Contact</a></li>
    </ul>
  </nav>
</header>

<script>
  const header = document.getElementById('header');
  const toggle = document.getElementById('navToggle');
  if (header && toggle) {
    const close = () => { header.classList.remove('nav-open'); toggle.setAttribute('aria-expanded', 'false'); };
    toggle.addEventListener('click', () => {
      const open = header.classList.toggle('nav-open');
      toggle.setAttribute('aria-expanded', String(open));
    });
    header.querySelectorAll('.nav-links a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  }
</script>
