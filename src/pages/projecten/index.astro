---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const themaLabel: Record<string, string> = {
  installaties: 'Interactieve installatie',
  webapps: 'Muzikale webapp',
  podium: 'Podium',
};

const projecten = (await getCollection('projecten')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const clean = (id: string) => id.replace(/\/index$/, '');
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Base title="Projecten — Studio Wotto" description="Interactieve installaties, muzikale webapps en muziekinstrumenten van Studio Wotto.">
  <SiteHeader />
  <section class="section section--coral">
    <div class="container"><h2>Onze projecten</h2></div>
  </section>
  <section class="section section--sun">
    <div class="container container--wide">
      <div class="grid">
        {projecten.map((p) => (
          <a class="project" href={base + 'projecten/' + clean(p.id)}>
            <div class="project__img"><Image src={p.data.cover} alt={p.data.alt ?? p.data.title} width={640} /></div>
            <h3>{p.data.title}</h3>
            <div class="project__theme">{themaLabel[p.data.thema]}</div>
          </a>
        ))}
      </div>
    </div>
  </section>
  <SiteFooter />
</Base>
