---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const pillarSlug: Record<string, string> = { installaties: 'interactieve-installaties', webapps: 'muzikale-webapps', podium: 'muziekinstrumenten' };
const pillarLabel: Record<string, string> = { installaties: 'Interactieve installaties', webapps: 'Muzikale webapps', podium: 'Podium & instrumenten' };
const clean = (id: string) => id.replace(/\/index$/, '');

export async function getStaticPaths() {
  const items = await getCollection('blog');
  return items.map((entry) => ({ params: { slug: entry.id.replace(/\/index$/, '') }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const thema = entry.data.thema as string | undefined;
const related = (await getCollection('blog'))
  .filter((x) => x.id !== entry.id && (thema ? x.data.thema === thema : true))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<Base title={entry.data.title + ' — Studio Wotto'} description={entry.data.excerpt}>
  <SiteHeader />

  <section class="section section--bubblegum">
    <div class="container" style="max-width:820px">
      {thema && <a class="chip" href={`/${pillarSlug[thema]}`}>{pillarLabel[thema]}</a>}
      <h1 style="font-size:clamp(30px,5vw,52px); margin-top:var(--space-4)">{entry.data.title}</h1>
      {entry.data.excerpt && <p class="lead" style="max-width:640px">{entry.data.excerpt}</p>}
    </div>
  </section>

  <section class="section section--sun">
    <div class="container" style="max-width:820px">
      {entry.data.cover && (
        <div style="border-radius:var(--radius-lg); overflow:hidden; margin-bottom:var(--space-6); box-shadow:var(--shadow-md)">
          <Image src={entry.data.cover} alt={entry.data.alt ?? entry.data.title} width={1200} />
        </div>
      )}
      <div class="prose"><Content /></div>
      {entry.data.tags.length > 0 && (
        <div class="cloud" style="margin-top:var(--space-6)">{entry.data.tags.map((t) => <span class="chip">{t}</span>)}</div>
      )}
    </div>
  </section>

  {related.length > 0 && (
    <section class="section section--mint">
      <div class="container container--wide">
        <h2 style="font-size:clamp(26px,4vw,40px); margin-bottom:var(--space-6)">Meer verhalen</h2>
        <div class="grid">
          {related.map((b) => (
            <a class="project" href={`/blog/${clean(b.id)}`}>
              <div class="project__img"><Image src={b.data.cover} alt={b.data.alt ?? b.data.title} width={480} /></div>
              <h3>{b.data.title}</h3>
              {b.data.excerpt && <p class="project__excerpt">{b.data.excerpt}</p>}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section section--ink" style="text-align:center">
    <div class="container">
      <h2 style="font-size:clamp(26px,4vw,40px)">Benieuwd wat we voor jou kunnen maken?</h2>
      <div style="margin-top:var(--space-6)"><a class="btn btn--light" href="/#contact">Neem contact op</a></div>
    </div>
  </section>

  <SiteFooter />
</Base>
